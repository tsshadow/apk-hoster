# APK Hoster Configuration
APP_NAME=ultrasonic
PORT=8275

# Local path where APKs are stored
DIST_DIR=dist

# Upload Security
UPLOAD_PASSWORD=
ALLOWED_IPS=

# Docker Configuration
DOCKER_IMAGE=tsshadow/apk-hoster

# Remote Deployment (for scripts/deploy.sh)
REMOTE_HOST=
REMOTE_USER=root
REMOTE_PASS=
REMOTE_DIST_PATH=/mnt/teun/ultrasonic-builds
DEPLOY_TARGET_NAME=APK Hoster
